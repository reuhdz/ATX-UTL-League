flowchart LR
    Seed([LEAGUE.seed]) --> RNG[mulberry32 rng]
    RNG --> Sched[buildSchedule]
    Sched --> Asm[MATCHES IIFE]
    RNG --> Play[playMatch per final]
    Play --> Line[lineup + nextGuest]
    Play --> Score[genGoals]
    Play --> Box[boxFor]
    Asm --> DB[DB derivations]
    Box --> DB
    DB --> UI[app.js tabs + charts]

